# Copy this file to .env and fill in your real key. .env is gitignored.
# cp .env.example .env

# Required: your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Model choices — live in one place so they're easy to swap.
LLM_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# Ingestion tuning (optional — sensible defaults live in config.py)
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
COLLECTION_NAME=docs
